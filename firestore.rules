rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'points', 'level']) &&
             data.username is string && data.username.size() >= 1 &&
             data.points is number &&
             data.level is number;
    }

    function isValidBet(data) {
      return data.keys().hasAll(['userId', 'selections', 'stake', 'totalOdds', 'status']) &&
             data.userId == request.auth.uid &&
             data.stake is number && data.stake > 0 &&
             data.status in ['CREATED', 'LOCKED', 'CANCELED'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    match /bets/{betId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBet(request.resource.data);
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId &&
        (request.resource.data.status == 'CANCELED' || request.resource.data.status == 'LOCKED')
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /rankings/{rankingId} {
      allow read: if isAuthenticated();
      // Allow authenticated writes for client-side weekly auto-close
      allow write: if isAuthenticated();
    }
  }
}
